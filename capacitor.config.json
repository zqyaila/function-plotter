{
  "appId": "com.aila.functionplotter",
  "appName": "函数绘图器",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0d0f14",
    "overrideUserAgent": "FunctionPlotter/1.0"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor": "#0d0f14",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0d0f14"
    }
  }
}
